generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Users & Auth ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          UserRole  @default(ADMIN)
  autoApprove   Boolean   @default(false)
  apiToken      String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  claimedRequests   Request[]  @relation("ClaimedBy")
  approvedRequests  Request[]  @relation("ApprovedBy")
  solutions         Solution[]
}

enum UserRole {
  ADMIN
  DEVELOPER
}

// ─── Conversations & Messages ───────────────────────────────

model Conversation {
  id            String              @id @default(cuid())
  visitorName   String?
  visitorEmail  String?
  userAgent     String?
  ipAddress     String?
  currentUrl    String?
  metadata      Json?
  status        ConversationStatus  @default(ACTIVE)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  messages      Message[]
  screenshots   Screenshot[]
  request       Request?
}

enum ConversationStatus {
  ACTIVE
  SUBMITTED
  ARCHIVED
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  sender          Sender
  content         String
  metadata        Json?
  createdAt       DateTime @default(now())

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

enum Sender {
  VISITOR
  BUGSY
}

model Screenshot {
  id              String   @id @default(cuid())
  conversationId  String
  filePath        String
  fileName        String
  fileSize        Int
  mimeType        String
  createdAt       DateTime @default(now())

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// ─── Requests & Solutions ───────────────────────────────────

model Request {
  id              String        @id @default(cuid())
  conversationId  String        @unique
  title           String
  description     String
  type            RequestType   @default(BUG)
  priority        Priority      @default(MEDIUM)
  status          RequestStatus @default(PENDING)
  claimedById     String?
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  conversation    Conversation  @relation(fields: [conversationId], references: [id])
  claimedBy       User?         @relation("ClaimedBy", fields: [claimedById], references: [id])
  approvedBy      User?         @relation("ApprovedBy", fields: [approvedById], references: [id])
  solutions       Solution[]
}

enum RequestType {
  BUG
  FEATURE
  FEEDBACK
  QUESTION
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RequestStatus {
  PENDING
  APPROVED
  IN_PROGRESS
  AWAITING_APPROVAL
  COMPLETED
  REJECTED
}

model Solution {
  id          String         @id @default(cuid())
  requestId   String
  developerId String
  summary     String
  diff        String?
  status      SolutionStatus @default(PENDING)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  request     Request @relation(fields: [requestId], references: [id])
  developer   User    @relation(fields: [developerId], references: [id])
}

enum SolutionStatus {
  PENDING
  APPROVED
  REJECTED
  APPLIED
}
